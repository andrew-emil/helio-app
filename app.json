{
  "expo": {
    "name": "Helio App",
    "slug": "helio-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon2.png",
    "scheme": "helioapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "bundleIdentifier": "com.andrewemil.helioapp",
      "icon": "./assets/images/icon2.png",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access so you can take photos.",
        "NSPhotoLibraryUsageDescription": "We need library access to let you choose photos.",
        "NSLocationWhenInUseUsageDescription": "We need location to show nearby items.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO",
        "NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon2.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.andrewemil.helioapp"
    },
    "splash": {
      "image": "./assets/images/icon2.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon2.png"
    },
    "extra": {
      "supportsRTL": true,
      "forcesRTL": true,
      "router": {},
      "eas": {
        "projectId": "92ae9139-6389-4fbe-bc0b-cef6354c5c17"
      },
      "EXPO_PUBLIC_APP_URL": "https://helio.example.com"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-notifications",
      [
        "expo-router",
        {
          "sitemap": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Cairo-Bold.ttf",
            "./assets/fonts/Cairo-Medium.ttf",
            "./assets/fonts/Cairo-Regular.ttf",
            "./assets/fonts/Cairo-SemiBold.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Cairo",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Cairo-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Cairo-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Cairo-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Cairo-SemiBold.ttf",
                    "weight": 600
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
